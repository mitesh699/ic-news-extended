{
  "name": "ic-news",
  "version": "1.0.0",
  "description": "Portfolio News Tracker — Initialized AI Engineer Take-Home",
  "main": "dist/src/backend/index.js",
  "scripts": {
    "dev": "tsx watch src/backend/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/src/backend/index.js",
    "scrape": "tsx scripts/scrape-portfolio.ts",
    "fetch-news": "tsx scripts/fetch-news.ts",
    "generate-summaries": "tsx scripts/generate-summaries.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && cd src/frontend && npx vitest run",
    "postinstall": "npx prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://mitesh699@github.com/mitesh699/ic-news.git"
  },
  "keywords": [],
  "author": "Mitesh Singh",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mitesh699/ic-news/issues"
  },
  "homepage": "https://github.com/mitesh699/ic-news#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@mastra/core": "^1.10.0",
    "@mastra/mcp": "^1.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/pdfkit": "^0.17.5",
    "async-retry": "^1.3.3",
    "bullmq": "^5.71.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^17.3.1",
    "exa-js": "^2.7.0",
    "hono": "^4.12.5",
    "marked": "^17.0.4",
    "node-cron": "^4.2.1",
    "openai": "^6.27.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.9",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
